# ─────────────────────────────────────────────────────────────
# FutureFin AI — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# ── SQLite (zero config — just set a path) ───────────────────
# The database file will be created automatically on first run.
SQLITE_PATH=./data/FutureFin.sqlite

# ── AI Provider (get free key at console.groq.com) ───────────
AI_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192
GROQ_FAST_MODEL=llama3-8b-8192

# Fallback (optional — if Groq is down)
OPENAI_API_KEY=

# Local Ollama fallback (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Auth secrets (CHANGE THESE — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ─
JWT_SECRET=change_this_to_a_random_64_char_string_before_deploying_not_this_value
JWT_REFRESH_SECRET=change_this_to_a_different_random_64_char_string_before_deploying
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
BCRYPT_ROUNDS=12

# ── Frontend URL (for CORS) ───────────────────────────────────
FRONTEND_URL=http://localhost:8080

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── Redis (optional — fallback to in-memory if not set) ──────
# Leave blank for local dev — works fine without Redis
REDIS_URL=

# ── Currency ──────────────────────────────────────────────────
USD_TO_INR_RATE=83

# ── Feature flags ─────────────────────────────────────────────
ETHICAL_AI_ENABLED=true
BIAS_DETECTION_ENABLED=true
LOG_LEVEL=info
